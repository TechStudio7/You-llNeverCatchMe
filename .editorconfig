# top-most EditorConfig file
root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{bat,ps1}]
# Ensure script files handle line endings correctly for Windows
end_of_line = crlf

[*.md]
trim_trailing_whitespace = false